# The Turso database URL for the Broadband business database
BROADBAND_TURSO_DATABASE_URL=libsql://your-database-name.turso.io
# The Turso authorization token for the Broadband business database
BROADBAND_TURSO_AUTH_TOKEN=your-turso-auth-token-here

# The Turso database URL for the Cable business database
CABLE_TURSO_DATABASE_URL=libsql://your-database-name.turso.io
# The Turso authorization token for the Cable business database
CABLE_TURSO_AUTH_TOKEN=your-turso-auth-token-here

# The admin username used to login to the system
ADMIN_USERNAME=your-admin-username
# The admin password used to login to the system
ADMIN_PASSWORD=your-secure-password-here
# Force sync administrative password on boot/server restart
SYNC_ADMIN_PASSWORD_ON_BOOT=true
# A cryptographically secure secret used for signing session cookies
SESSION_SECRET=replace-with-a-random-32-char-secret
